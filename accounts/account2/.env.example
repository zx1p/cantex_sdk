# Credentials for account2
# Copy this file to .env and fill in your real keys.
# This file is safe to commit – .env is git-ignored.

# Ed25519 operator private key (hex)
CANTEX_OPERATOR_KEY=your_operator_key_hex_here

# secp256k1 trading / intent private key (hex)
CANTEX_TRADING_KEY=your_trading_key_hex_here

# Optional: override the API base URL
# CANTEX_BASE_URL=https://api.testnet.cantex.io