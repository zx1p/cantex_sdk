# Cantex Swap Bot — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values:
#
#   cp .env.example .env
#
# .env is already listed in .gitignore and will never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# API base URL (mainnet or testnet)
CANTEX_BASE_URL=https://api.testnet.cantex.io

# Operator Ed25519 private key — hex-encoded, no 0x prefix
CANTEX_OPERATOR_KEY=your_operator_ed25519_private_key_hex_here

# Intent / trading secp256k1 private key — hex-encoded, no 0x prefix
CANTEX_TRADING_KEY=your_trading_secp256k1_private_key_hex_here